# Application
DEBUG=true
ENVIRONMENT=development

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_rag

# Ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-processing

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=enterprise-rag

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# File Upload
UPLOAD_DIR=data/uploads
MAX_FILE_SIZE_MB=50

# Resource Management (GPU/Memory Protection)
# Adjust these if you experience system slowdowns during document processing
EMBEDDING_BATCH_SIZE=5
EMBEDDING_BATCH_DELAY_SECONDS=0.5
EMBEDDING_REQUEST_TIMEOUT=30.0
MAX_CONCURRENT_EMBEDDINGS=1
